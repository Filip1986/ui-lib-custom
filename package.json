{
  "name": "ui-lib-custom",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build ui-lib-custom",
    "build:minimal": "ng build minimal",
    "build:demo": "ng build demo",
    "serve:demo": "ng serve demo",
    "watch": "ng build --watch --configuration development",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:a11y": "jest --config jest.a11y.config.js",
    "test:a11y:watch": "jest --config jest.a11y.config.js --watch",
    "test:a11y:e2e": "playwright test e2e/a11y.spec.ts",
    "test:a11y:all": "npm run test:a11y && npm run test:a11y:e2e",
    "test:a11y:report": "node scripts/generate-a11y-report.js",
    "test:all": "npm run test && npm run test:a11y",
    "format": "prettier --write \"projects/**/*.{ts,html,scss,css,js,json,md}\" \"docs/**/*.{md}\" \"*.{json,md}\"",
    "format:check": "prettier --check \"projects/**/*.{ts,html,scss,css,js,json,md}\" \"docs/**/*.{md}\" \"*.{json,md}\"",
    "storybook": "cross-env NODE_ENV=development ng run ui-lib-custom:storybook",
    "build-storybook": "cross-env NODE_ENV=production ng run ui-lib-custom:build-storybook",
    "lint": "npx eslint",
    "lint:fix": "eslint . --fix",
    "lint:ci": "eslint . --max-warnings 0",
    "bundlesize": "bundlesize",
    "prepare": "husky install",
    "coverage:summary": "node scripts/coverage-summary.js --threshold 90",
    "verify:tree-shaking": "node scripts/verify-tree-shaking.js",
    "verify:tree-shaking:dry": "node scripts/verify-tree-shaking.js --dry-run"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.1.1",
    "@angular/compiler": "^21.1.1",
    "@angular/core": "^21.1.1",
    "@angular/forms": "^21.1.1",
    "@angular/platform-browser": "^21.1.1",
    "@angular/router": "^21.1.1",
    "@ng-icons/bootstrap-icons": "^33.0.0",
    "@ng-icons/core": "^33.0.0",
    "@ng-icons/heroicons": "^33.0.0",
    "@ng-icons/lucide": "^33.0.0",
    "@ng-icons/material-symbols": "^33.0.0",
    "@ng-icons/tabler-icons": "^33.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/architect": "^0.2101.1",
    "@angular-devkit/core": "^21.1.1",
    "@angular-eslint/builder": "^21.2.0",
    "@angular-eslint/eslint-plugin": "^21.2.0",
    "@angular-eslint/eslint-plugin-template": "^21.2.0",
    "@angular-eslint/template-parser": "^21.2.0",
    "@angular/build": "^21.1.1",
    "@angular/cli": "^21.1.1",
    "@angular/compiler-cli": "^21.1.1",
    "@angular/platform-browser-dynamic": "^21.1.5",
    "@axe-core/playwright": "^4.9.1",
    "@compodoc/compodoc": "^1.1.16",
    "@playwright/test": "^1.50.0",
    "@storybook/addon-a11y": "^10.2.12",
    "@storybook/addon-docs": "^10.2.12",
    "@storybook/addon-onboarding": "^10.2.12",
    "@storybook/angular": "^10.2.12",
    "@types/jest": "^29.5.12",
    "@types/jest-axe": "^3.5.6",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "axe-core": "^4.9.1",
    "bundlesize": "^0.18.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.0",
    "eslint-plugin-jsdoc": "^62.7.1",
    "husky": "^9.1.7",
    "jest": "^30.0.0",
    "jest-axe": "^7.0.0",
    "jest-environment-jsdom": "^30.0.0",
    "jest-preset-angular": "^16.0.0",
    "jsdom": "^26.0.0",
    "lint-staged": "^15.2.10",
    "ng-packagr": "^21.1.0",
    "playwright": "^1.50.0",
    "prettier": "^3.8.1",
    "storybook": "^10.2.12",
    "ts-node": "^10.9.2",
    "typescript": "5.9"
  },
  "bundlesize": [
    {
      "path": "./dist/ui-lib-custom/fesm2022/ui-lib-custom.mjs",
      "maxSize": "590 kB"
    },
    {
      "path": "./dist/ui-lib-custom/fesm2022/ui-lib-custom-button.mjs",
      "maxSize": "50 kB"
    }
  ],
  "lint-staged": {
    "*.ts": [
      "scripts/lint-staged-eslint.sh",
      "prettier --write"
    ],
    "*.scss": [
      "prettier --write"
    ]
  }
}
