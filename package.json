{
  "name": "ui-lib-custom",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port 4201",
    "build": "ng build ui-lib-custom",
    "build:minimal": "ng build minimal",
    "build:demo": "ng build demo",
    "prebuild:demo": "node scripts/generate-snippets.mjs",
    "serve:demo": "ng serve demo",
    "preserve:demo": "node scripts/generate-snippets.mjs",
    "snippets": "node scripts/generate-snippets.mjs",
    "watch": "ng build --watch --configuration development",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:a11y": "jest --config jest.a11y.config.js",
    "test:a11y:watch": "jest --config jest.a11y.config.js --watch",
    "test:a11y:e2e": "playwright test e2e/a11y.spec.ts",
    "test:a11y:e2e:sweep": "playwright test e2e/a11y-full-sweep.spec.ts",
    "test:a11y:e2e:interactions": "playwright test e2e/a11y-interactions.spec.ts",
    "test:e2e:overlay": "playwright test e2e/overlay-mounting.spec.ts",
    "test:e2e": "playwright test",
    "test:a11y:all": "npm run test:a11y && npm run test:a11y:e2e && npm run test:a11y:e2e:interactions && npm run test:a11y:e2e:sweep",
    "test:a11y:report": "node scripts/generate-a11y-report.js",
    "test:all": "npm run test && npm run test:a11y",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "storybook": "cross-env NODE_ENV=development ng run ui-lib-custom:storybook",
    "build-storybook": "cross-env NODE_ENV=production ng run ui-lib-custom:build-storybook",
    "lint": "npx eslint",
    "lint:fix": "eslint . --fix",
    "lint:organization:fix": "eslint \"projects/**/*.{ts,html}\" \"e2e/**/*.{ts,html}\" \".storybook/**/*.{ts,html}\" \"setup-a11y.ts\" --fix --no-warn-ignored",
    "lint:ci": "eslint . --max-warnings 0",
    "lint:css": "stylelint \"**/*.{scss,css}\" --allow-empty-input",
    "lint:css:fix": "stylelint \"**/*.{scss,css}\" --allow-empty-input --fix",
    "lint:css:ci": "stylelint \"**/*.{scss,css}\" --allow-empty-input --max-warnings 0",
    "lint:css:motion": "stylelint \"projects/ui-lib-custom/**/*.scss\" --config stylelint.motion.config.mjs --custom-formatter scripts/motion-formatter.mjs",
    "bundlesize": "bundlesize",
    "bundlesize:snapshot": "node scripts/snapshot-bundle-sizes.mjs",
    "bundlesize:check": "node scripts/check-bundle-budget.mjs",
    "postinstall": "husky install",
    "coverage:summary": "node scripts/coverage-summary.js --threshold 90",
    "verify:tree-shaking": "node scripts/verify-tree-shaking.js",
    "verify:tree-shaking:dry": "node scripts/verify-tree-shaking.js --dry-run",
    "knip": "knip --config knip.json --reporter compact",
    "knip:strict": "knip --config knip.json --reporter compact --strict",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p projects/ui-lib-custom/tsconfig.lib.json && tsc --noEmit -p projects/ui-lib-custom/tsconfig.spec.json && tsc --noEmit -p projects/demo/tsconfig.app.json && tsc --noEmit -p projects/demo/tsconfig.spec.json",
    "check": "npm run format:check && npm run lint:ci && npm run lint:css && npm run typecheck && npm test",
    "health": "node scripts/health-check.mjs",
    "docs:reference": "node scripts/generate-reference-doc.mjs --all",
    "docs:i18n": "node scripts/generate-i18n-catalogue.mjs",
    "docs:i18n:check": "node scripts/generate-i18n-catalogue.mjs --check",
    "competitive:primeng": "node scripts/extract-primeng-api.mjs",
    "competitive:primeng:check": "node scripts/extract-primeng-api.mjs --check",
    "competitive:surfaces": "node scripts/competitive-surfaces.mjs",
    "competitive:metrics": "node scripts/component-quality-metrics.mjs",
    "check:i18n": "node scripts/check-i18n.mjs"
  },
  "engines": {
    "node": ">=22"
