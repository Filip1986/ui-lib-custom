{
  "name": "ui-lib-custom",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:minimal": "ng build minimal",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:a11y": "jest --config jest.a11y.config.js",
    "test:a11y:watch": "jest --config jest.a11y.config.js --watch",
    "test:all": "npm run test && npm run test:a11y",
    "format": "prettier --write \"projects/**/*.{ts,html,scss,css,js,json,md}\" \"docs/**/*.{md}\" \"*.{json,md}\"",
    "format:check": "prettier --check \"projects/**/*.{ts,html,scss,css,js,json,md}\" \"docs/**/*.{md}\" \"*.{json,md}\""
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.1.1",
    "@angular/compiler": "^21.1.1",
    "@angular/core": "^21.1.1",
    "@angular/forms": "^21.1.1",
    "@angular/platform-browser": "^21.1.1",
    "@angular/router": "^21.1.1",
    "@ng-icons/bootstrap-icons": "^33.0.0",
    "@ng-icons/core": "^33.0.0",
    "@ng-icons/heroicons": "^33.0.0",
    "@ng-icons/lucide": "^33.0.0",
    "@ng-icons/material-symbols": "^33.0.0",
    "@ng-icons/tabler-icons": "^33.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.1",
    "@angular/cli": "^21.1.1",
    "@angular/compiler-cli": "^21.1.1",
    "@angular/platform-browser-dynamic": "^21.1.5",
    "@axe-core/playwright": "^4.9.1",
    "@types/jasmine": "~5.1.0",
    "@types/jest": "^29.5.12",
    "@types/jest-axe": "^3.5.6",
    "axe-core": "^4.9.1",
    "jasmine-core": "~5.4.0",
    "jest": "^30.0.0",
    "jest-axe": "^7.0.0",
    "jest-environment-jsdom": "^30.0.0",
    "jest-preset-angular": "^16.0.0",
    "jsdom": "^26.0.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^21.1.0",
    "prettier": "^3.8.1",
    "typescript": "5.9",
    "zone.js": "^0.15.0"
  }
}
