{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "ui-lib-custom": {
      "projectType": "library",
      "root": "projects/ui-lib-custom",
      "sourceRoot": "projects/ui-lib-custom/src",
      "prefix": "uilib",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/ui-lib-custom/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/ui-lib-custom/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/ui-lib-custom/**/*.ts",
              "projects/ui-lib-custom/**/*.html"
            ]
          }
        },
        "storybook": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "configDir": ".storybook",
            "tsConfig": ".storybook/tsconfig.json",
            "browserTarget": "demo:build",
            "compodoc": true,
            "compodocArgs": ["-e", "json", "-d", "projects/ui-lib-custom"],
            "port": 6006
          }
        },
        "build-storybook": {
          "builder": "@storybook/angular:build-storybook",
          "options": {
            "configDir": ".storybook",
            "tsConfig": ".storybook/tsconfig.json",
            "browserTarget": "demo:build",
            "compodoc": true,
            "compodocArgs": ["-e", "json", "-d", "projects/ui-lib-custom"],
            "outputDir": "dist/storybook/ui-lib-custom"
          }
        }
      }
    },
    "demo": {
      "projectType": "application",
      "schematics": {},
      "root": "projects/demo",
      "sourceRoot": "projects/demo/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "projects/demo/src/main.ts",
            "tsConfig": "projects/demo/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/demo/public"
              }
            ],
            "styles": [
              "projects/demo/src/styles.scss",
              "projects/ui-lib-custom/src/lib/themes/themes.scss",
              "projects/ui-lib-custom/src/lib/styles/dark-theme.scss"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "1.5MB",
                  "maximumError": "2MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "15kB",
                  "maximumError": "22kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "demo:build:production"
            },
            "development": {
              "buildTarget": "demo:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n"
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": ["projects/demo/**/*.ts", "projects/demo/**/*.html"]
          }
        }
      }
    },
    "minimal": {
      "projectType": "application",
      "schematics": {},
      "root": "projects/minimal",
      "sourceRoot": "projects/minimal/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "projects/minimal/src/main.ts",
            "tsConfig": "projects/minimal/tsconfig.app.json",
            "assets": [],
            "styles": ["projects/minimal/src/styles.scss"]
          },
          "configurations": {
            "production": {
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        }
      }
    }
  },
  "cli": {
    "analytics": "fa3a2789-b385-4273-8b65-ffab424f7cce"
  }
}
