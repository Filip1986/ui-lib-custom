{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "projects/demo/src/main.ts",
    "projects/minimal/src/main.ts",
    "projects/ui-lib-custom/src/public-api.ts",
    "projects/ui-lib-custom/src/lib/**/index.ts",
    "scripts/**/*.{js,ts}",
    "e2e/**/*.ts"
  ],
  "project": [
    "projects/**/*.{ts,html,scss}",
    "*.{js,ts}",
    "docs/**/*.md"
  ],
  "ignore": [
    "coverage/**",
    "dist/**",
    "out-tsc/**",
    "playwright-report/**",
    "storybook-static/**",
    "tmp/**",
    "projects/ui-lib-custom/**/public-api.ts",
    "projects/ui-lib-custom/**/src/public-api.ts",
    "projects/ui-lib-custom/.storybook/**",
    "projects/ui-lib-custom/src/stories/**",
    "projects/ui-lib-custom/tokens/dist/**",
    "projects/demo/src/app/examples/layout-basic-example.component.ts",
    "projects/demo/src/app/pages/layouts/layouts.component.ts",
    "projects/demo/src/app/pages/starter-template/starter-template-demo.component.ts",
    "projects/demo/src/app/shared/doc-page/doc-toc.component.ts",
    "projects/demo/src/app/shared/index.ts",
    "projects/demo/src/app/shared/theme-editor/**",
    "projects/minimal/src/app/app.routes.ts"
  ],
  "ignoreBinaries": [
    "scripts/lint-staged-eslint.sh"
  ],
  "ignoreDependencies": [
    "ts-node"
  ]
}

