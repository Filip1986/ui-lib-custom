{
  "name": "ui-lib-custom",
  "version": "1.0.0",
  "description": "A flexible Angular UI component library with multiple design variants.",
  "author": "Luca Filip <filip.luca.work@gmail.com>",
  "license": "MIT",
  "keywords": [
    "angular",
    "components",
    "ui",
    "ui-library",
    "material-design",
    "bootstrap",
    "button",
    "card",
    "angular-components",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/ui-lib-custom.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/ui-lib-custom/issues"
  },
  "homepage": "https://github.com/yourusername/ui-lib-custom#readme",
  "peerDependencies": {
    "@angular/common": "^21.0.0 || ^22.0.0",
    "@angular/core": "^21.0.0 || ^22.0.0"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "exports": {
    "./editor": {
      "esm2022": "./esm2022/editor/index.mjs",
      "esm": "./esm2022/editor/index.mjs"
    },
    "./date-picker": {
      "esm2022": "./esm2022/date-picker/index.mjs",
      "esm": "./esm2022/date-picker/index.mjs"
    },
    "./themes/themes.css": {
      "default": "./themes/themes.css"
    },
    "./themes/themes.scss": {
      "default": "./themes/themes.scss"
    },
    "./styles/*": {
      "default": "./styles/*"
    }
  },
  "typesVersions": {
    "*": {
      "editor": [
        "./editor/index.d.ts"
      ],
      "date-picker": [
        "./date-picker/index.d.ts"
      ],
      "testing": [
        "./testing/index.d.ts"
      ]
    }
  }
}
