# Auto-detect text files and normalise line endings to LF
* text=auto eol=lf

# Explicitly declare text files
*.ts        text eol=lf
*.html      text eol=lf
*.scss      text eol=lf
*.css       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.mjs       text eol=lf
*.js        text eol=lf
*.svg       text eol=lf
*.stories.ts text eol=lf

# Binary files — do not modify
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.pdf       binary

